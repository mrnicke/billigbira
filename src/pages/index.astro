---
import PageShell from "../components/PageShell.astro";
import PriceList from "../components/PriceList";
import ReportPriceForm from "../components/ReportPriceForm";
import { getBeerPriceList } from "../lib/data/prices";
import { formatPricePerLiter, formatSek } from "../lib/pricing";

const baseUrl = import.meta.env.BASE_URL;
const normalizedBaseUrl = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
const beerPriceList = await getBeerPriceList();
const prices = beerPriceList.prices;
const cheapestPrice = prices[0] ?? null;
const venueCount = new Set(prices.map((price) => price.venue.id)).size;
const latestObservation = prices.map((price) => price.observed_at).sort((a, b) => b.localeCompare(a, "sv"))[0] ?? null;
const latestObservationLabel = latestObservation
  ? new Intl.DateTimeFormat("sv-SE", { day: "numeric", month: "short" }).format(new Date(`${latestObservation}T12:00:00`))
  : "Väntar på rapport";
---

<PageShell
  title="Billig Bira | Billig öl i Norrköping"
  description="Billig Bira är en svensk webbapp för att snabbt hitta billig öl i Norrköping."
>
  <main>
    <section class="bg-night px-4 py-8 text-white sm:px-6 sm:py-12 lg:px-8">
      <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[1fr_0.9fr] lg:items-center">
        <div class="max-w-2xl">
          <p class="text-sm font-black uppercase tracking-normal text-malt">Norrköpings ölprisguide</p>
          <h1 class="mt-3 text-4xl font-black leading-tight sm:text-6xl lg:text-7xl">Hitta billigaste biran utan att gissa.</h1>
          <p class="mt-5 max-w-xl text-lg leading-8 text-white/80">
            Jämför pris, volym och kr/liter på samma ställe. Billigast ligger först, och nya fynd kan rapporteras på under en minut.
          </p>
          <div class="mt-7 flex flex-col gap-3 sm:flex-row">
            <a href="#priser" class="rounded-md bg-malt px-5 py-3 text-center font-black text-night hover:bg-white">Se billigast just nu</a>
            <a href="#rapportera" class="rounded-md border border-white/20 bg-white/10 px-5 py-3 text-center font-black text-white hover:border-malt hover:text-malt">
              Rapportera ett pris
            </a>
          </div>
        </div>

        <div class="relative min-h-[330px] overflow-hidden rounded-lg border border-white/10 bg-paper shadow-soft">
          <img
            src={`${normalizedBaseUrl}hero-billig-bira.svg`}
            alt="Illustration av Norrköping, pubbord och ölglas"
            class="h-full min-h-[330px] w-full object-cover"
            loading="eager"
          />
          <div class="absolute bottom-0 left-0 right-0 bg-night/90 p-4 text-white">
            <p class="text-sm font-bold text-white/70">Billigast just nu</p>
            {
              cheapestPrice ? (
                <p class="mt-1 text-2xl font-black">
                  {formatSek(cheapestPrice.price_sek)} för {cheapestPrice.volume_cl} cl hos {cheapestPrice.venue.name}
                </p>
              ) : (
                <p class="mt-1 text-2xl font-black">Inga priser publicerade ännu</p>
              )
            }
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-line bg-paper px-4 py-5 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-6xl gap-3 sm:grid-cols-3">
        <div class="rounded-md border border-line bg-foam p-4">
          <p class="text-xs font-black uppercase text-copper">Lägsta literpris</p>
          <p class="mt-1 text-2xl font-black text-ink">{cheapestPrice ? formatPricePerLiter(cheapestPrice.price_per_liter_sek) : "Inga priser än"}</p>
          <p class="mt-1 text-sm font-semibold text-ink/60">{cheapestPrice ? cheapestPrice.venue.name : "Rapportera första fyndet"}</p>
        </div>
        <div class="rounded-md border border-line bg-white p-4">
          <p class="text-xs font-black uppercase text-copper">Ställen i listan</p>
          <p class="mt-1 text-2xl font-black text-ink">{venueCount}</p>
          <p class="mt-1 text-sm font-semibold text-ink/60">Aktiva serveringsställen med priser</p>
        </div>
        <div class="rounded-md border border-line bg-white p-4">
          <p class="text-xs font-black uppercase text-copper">Senast uppdaterat</p>
          <p class="mt-1 text-2xl font-black text-ink">{latestObservationLabel}</p>
          <p class="mt-1 text-sm font-semibold text-ink/60">Baserat på senaste observation</p>
        </div>
      </div>
    </section>

    <PriceList prices={beerPriceList.prices} dataStatus={beerPriceList.status} client:load />
    <ReportPriceForm client:load />
  </main>
</PageShell>
