---
import PageShell from "../components/PageShell.astro";
import PriceList from "../components/PriceList";
import ReportPriceForm from "../components/ReportPriceForm";
import { getBeerPriceList } from "../lib/data/prices";
import { formatPricePerLiter, formatSek } from "../lib/pricing";

const beerPriceList = await getBeerPriceList();
const prices = beerPriceList.prices;
const cheapestPrice = prices[0] ?? null;
const venueCount = new Set(prices.map((price) => price.venue.id)).size;
const latestObservation = prices.map((price) => price.observed_at).sort((a, b) => b.localeCompare(a, "sv"))[0] ?? null;
const latestObservationLabel = latestObservation
  ? new Intl.DateTimeFormat("sv-SE", { day: "numeric", month: "short" }).format(new Date(`${latestObservation}T12:00:00`))
  : "Väntar";
---

<PageShell
  title="Billig Bira | Billig öl i Norrköping"
  description="Billig Bira hjälper dig hitta billig öl i Norrköping."
>
  <main class="min-h-screen overflow-x-hidden bg-[radial-gradient(circle_at_top,_rgba(242,184,75,0.18),_transparent_34rem),linear-gradient(180deg,#0d1110_0%,#141a17_42%,#0d1110_100%)] px-4 pb-28 pt-24 md:px-6 md:pb-16">
    <div class="mx-auto min-w-0 max-w-md md:max-w-5xl">
      <section id="billigast" class="grid gap-4 md:grid-cols-[0.9fr_1.1fr] md:items-end">
        <div class="pt-2">
          <p class="text-sm font-black uppercase tracking-normal text-malt">Billig Bira</p>
          <h1 class="mt-2 text-4xl font-black leading-tight text-foam sm:text-5xl">Jämför ölpriser i Norrköping.</h1>
          <p class="mt-3 max-w-sm text-base font-semibold leading-7 text-foam/70">
            Hitta billigast just nu och rapportera nya priser när du är ute.
          </p>
        </div>

        <article class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.08] p-4 shadow-app backdrop-blur-xl">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-sm font-black text-malt">Billigast just nu</p>
              <p class="mt-1 text-sm font-semibold text-foam/60">Sorterat på kr/liter</p>
            </div>
            <span class="rounded-full bg-hop/[0.18] px-3 py-1 text-xs font-black text-hop ring-1 ring-hop/25">
              Norrköping
            </span>
          </div>

          {
            cheapestPrice ? (
              <div class="mt-5">
                <p class="text-6xl font-black leading-none text-lager">{formatPricePerLiter(cheapestPrice.price_per_liter_sek).replace(" kr/liter", "")}</p>
                <p class="mt-1 text-sm font-black uppercase tracking-normal text-foam/50">kr/liter</p>
                <div class="mt-5 rounded-3xl bg-night/60 p-4 ring-1 ring-white/10">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <h2 class="text-2xl font-black text-foam">{cheapestPrice.venue.name}</h2>
                      <p class="mt-1 text-sm font-semibold text-foam/60">{cheapestPrice.beer?.name || cheapestPrice.beer_name}</p>
                    </div>
                    <p class="shrink-0 text-right text-lg font-black text-foam">
                      {formatSek(cheapestPrice.price_sek)}
                      <span class="block text-xs font-bold text-foam/50">{cheapestPrice.volume_cl} cl</span>
                    </p>
                  </div>
                  <p class="mt-3 text-xs font-bold text-foam/50">Observerat {latestObservationLabel}</p>
                </div>
              </div>
            ) : (
                <div class="mt-5 rounded-3xl bg-night/60 p-4 ring-1 ring-white/10">
                <h2 class="text-2xl font-black text-foam">Inga priser än</h2>
                <p class="mt-2 text-sm font-semibold text-foam/60">Rapportera första fyndet.</p>
              </div>
            )
          }

          <div class="mt-5 grid grid-cols-2 gap-3">
            <a href="#priser" class="grid min-h-12 place-items-center rounded-2xl bg-malt px-4 text-center text-sm font-black text-night hover:bg-lager">
              Visa listan
            </a>
            <a href="#rapportera" class="grid min-h-12 place-items-center rounded-2xl border border-white/10 bg-white/[0.08] px-4 text-center text-sm font-black text-foam hover:bg-white/[0.14]">
              Rapportera pris
            </a>
          </div>
        </article>
      </section>

      <section class="mt-4 grid grid-cols-3 gap-2">
        <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-3">
          <p class="text-[0.68rem] font-black uppercase text-foam/50">Lägst</p>
          <p class="mt-1 text-lg font-black text-foam">{cheapestPrice ? formatPricePerLiter(cheapestPrice.price_per_liter_sek).replace(" kr/liter", "") : "-"}</p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-3">
          <p class="text-[0.68rem] font-black uppercase text-foam/50">Ställen</p>
          <p class="mt-1 text-lg font-black text-foam">{venueCount}</p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-3">
          <p class="text-[0.68rem] font-black uppercase text-foam/50">Senast</p>
          <p class="mt-1 text-lg font-black text-foam">{latestObservationLabel}</p>
        </div>
      </section>

      <PriceList prices={beerPriceList.prices} client:load />
      <ReportPriceForm client:load />
    </div>
  </main>
</PageShell>
